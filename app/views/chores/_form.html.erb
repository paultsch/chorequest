<%= form_with(model: chore, local: true, class: 'space-y-6', multipart: true,
      data: { controller: 'improve-definition' }) do |form| %>
  <% if chore.errors.any? %>
    <div class="p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-lg">
      <h2 class="font-semibold"><%= pluralize(chore.errors.count, "error") %> prohibited this chore from being saved:</h2>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% chore.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, class: 'block text-sm font-medium text-gray-700' %>
    <%= form.text_field :name, id: 'chore_name',
          class: 'mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400',
          data: { 'improve-definition-target': 'choreName' } %>
  </div>

  <div>
    <%= form.label :description, class: 'block text-sm font-medium text-gray-700' %>
    <%= form.text_area :description,
          class: 'mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400',
          rows: 4, data: { 'improve-definition-target': 'description' } %>
  </div>

  <div>
    <div class="flex items-center justify-between">
      <%= form.label :definition_of_done, class: 'block text-sm font-medium text-gray-700' %>
      <button type="button"
              class="text-xs text-purple-600 hover:text-purple-800 underline disabled:opacity-40 disabled:cursor-not-allowed"
              data-improve-definition-target="button"
              data-action="click->improve-definition#improve">
        Improve with AI
      </button>
    </div>
    <%= form.text_area :definition_of_done,
          class: 'mt-1 block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400',
          rows: 3, data: { 'improve-definition-target': 'definitionOfDone' } %>
    <span class="text-xs text-red-500 mt-1" data-improve-definition-target="status"></span>
  </div>

  <div>
    <%= form.label :token_amount, class: 'block text-sm font-medium text-gray-700' %>
    <%= form.number_field :token_amount, min: 0, max: 200, step: 1,
          class: 'mt-1 block w-40 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400' %>
    <p class="text-xs text-gray-500 mt-1">Enter a token value between 0 and 200.</p>
  </div>

  <div>
    <%= form.label :frequency_days, "Repeats every (days)", class: 'block text-sm font-medium text-gray-700' %>
    <%= form.number_field :frequency_days, min: 1, step: 1, placeholder: 'e.g. 7',
          class: 'mt-1 block w-40 px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-green-400' %>
    <p class="text-xs text-gray-500 mt-1">Leave blank if this chore doesn't repeat on a schedule.</p>
  </div>

  <%# Chore-level model photo %>
  <div>
    <p class="block text-sm font-medium text-gray-700">Example photo <span class="font-normal text-gray-400">(optional)</span></p>
    <% if chore.model_photo.attached? %>
      <div class="mt-2 mb-2">
        <%= image_tag chore.model_photo, class: 'w-32 h-32 object-cover rounded-lg border border-gray-200' %>
      </div>
      <%= form.label :model_photo, "Change photo", class: 'block text-xs text-gray-500 mb-1' %>
    <% else %>
      <p class="text-xs text-gray-500 mt-1 mb-2">Show your child exactly what "done" looks like.</p>
    <% end %>
    <%= form.file_field :model_photo, accept: 'image/*',
          class: 'block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-amber-50 file:text-amber-700 hover:file:bg-amber-100' %>
  </div>

  <%# Task section — hidden by default, revealed via <details> %>
  <details <%= 'open' if chore.chore_tasks.any? %> class="group"
           data-controller="chore-tasks"
           data-chore-tasks-suggest-url-value="/chores/suggest_tasks">
    <summary class="cursor-pointer list-none flex items-center gap-2
                    text-sm font-semibold text-indigo-700 hover:text-indigo-900 select-none
                    py-2 px-3 bg-indigo-50 rounded-lg border border-indigo-100">
      <svg class="w-4 h-4 transition-transform duration-200 group-open:rotate-90 shrink-0"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      Break it into steps <span class="font-normal text-indigo-400">(optional)</span>
    </summary>

    <div class="mt-3 space-y-3">
      <%# Rue suggest button %>
      <div class="flex items-center gap-3">
        <button type="button"
                data-action="click->chore-tasks#suggestTasks"
                data-chore-tasks-target="suggestButton"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm bg-violet-50 hover:bg-violet-100 text-violet-700 font-medium rounded-lg border border-violet-200 transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          <span data-chore-tasks-target="suggestSpinner" class="hidden">
            <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </span>
          <span data-chore-tasks-target="suggestLabel">Suggest steps with Rue</span>
        </button>
        <span data-chore-tasks-target="suggestError" class="text-xs text-red-500 hidden"></span>
      </div>

      <div data-chore-tasks-target="taskList" class="space-y-2 min-h-[2rem]">
        <% chore.chore_tasks.each_with_index do |task, i| %>
          <div class="chore-task-row bg-gray-50 rounded-lg border border-gray-200 p-2 space-y-2">
            <%= form.fields_for :chore_tasks, task do |tf| %>
              <%= tf.hidden_field :id %>
              <%= tf.hidden_field :position, value: i %>
              <%= tf.hidden_field :_destroy, value: false %>
              <div class="flex items-center gap-2">
                <span class="text-gray-400 text-sm font-mono w-5 text-center shrink-0"><%= i + 1 %>.</span>
                <%= tf.text_field :title,
                      placeholder: "e.g. Make the bed",
                      class: 'flex-1 px-2 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400' %>
                <div class="flex gap-1 shrink-0">
                  <button type="button" data-action="click->chore-tasks#moveUp"
                          class="p-1 text-gray-400 hover:text-gray-700 rounded" title="Move up">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                    </svg>
                  </button>
                  <button type="button" data-action="click->chore-tasks#moveDown"
                          class="p-1 text-gray-400 hover:text-gray-700 rounded" title="Move down">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <button type="button" data-action="click->chore-tasks#removeTask"
                          class="p-1 text-red-400 hover:text-red-600 rounded" title="Remove task">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                  </button>
                </div>
              </div>
              <%# Photo required toggle + model photo per task %>
              <div class="flex flex-wrap items-center gap-4 pl-7">
                <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700 select-none">
                  <%= tf.check_box :photo_required, class: 'rounded border-gray-300 text-indigo-600 focus:ring-indigo-500' %>
                  <span>Photo required</span>
                </label>
                <div class="flex-1 min-w-[200px]">
                  <% if task.model_photo.attached? %>
                    <div class="flex items-center gap-2 mb-1">
                      <%= image_tag task.model_photo, class: 'w-10 h-10 object-cover rounded border border-gray-200' %>
                      <span class="text-xs text-gray-500">Change reference photo:</span>
                    </div>
                  <% else %>
                    <span class="text-xs text-gray-400 block mb-1">Reference photo (optional):</span>
                  <% end %>
                  <%= tf.file_field :model_photo, accept: 'image/*',
                        class: 'block w-full text-xs text-gray-700 file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:text-xs file:font-medium file:bg-gray-100 file:text-gray-600 hover:file:bg-gray-200' %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <div class="flex justify-between items-center pt-1">
        <button type="button"
                data-action="click->chore-tasks#addTask"
                class="px-3 py-1.5 text-sm bg-indigo-50 hover:bg-indigo-100 text-indigo-700 font-medium rounded-lg border border-indigo-200 transition-colors">
          + Add Step
        </button>
      </div>

      <%# Hidden template row — cloned by Stimulus when "Add Step" is clicked %>
      <template data-chore-tasks-target="template">
        <div class="chore-task-row bg-gray-50 rounded-lg border border-gray-200 p-2 space-y-2">
          <div class="flex items-center gap-2">
            <input type="hidden" name="chore[chore_tasks_attributes][__INDEX__][position]" value="__POSITION__">
            <span class="text-gray-400 text-sm font-mono w-5 text-center shrink-0">·</span>
            <input type="text"
                   name="chore[chore_tasks_attributes][__INDEX__][title]"
                   placeholder="e.g. Make the bed"
                   class="flex-1 px-2 py-1.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-400">
            <div class="flex gap-1 shrink-0">
              <button type="button" data-action="click->chore-tasks#moveUp"
                      class="p-1 text-gray-400 hover:text-gray-700 rounded" title="Move up">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                </svg>
              </button>
              <button type="button" data-action="click->chore-tasks#moveDown"
                      class="p-1 text-gray-400 hover:text-gray-700 rounded" title="Move down">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <button type="button" data-action="click->chore-tasks#removeTask"
                      class="p-1 text-red-400 hover:text-red-600 rounded" title="Remove task">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            </div>
          </div>
          <%# Photo required toggle — reference photo upload is available after saving via the edit form %>
          <div class="pl-7">
            <label class="flex items-center gap-2 cursor-pointer text-sm text-gray-700 select-none">
              <input type="checkbox"
                     name="chore[chore_tasks_attributes][__INDEX__][photo_required]"
                     value="1"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <span>Photo required</span>
            </label>
            <p class="text-xs text-gray-400 mt-1">Save first, then re-open to upload a reference photo per step.</p>
          </div>
        </div>
      </template>
    </div>
  </details>

  <div>
    <button type="submit" class="w-full inline-flex items-center justify-center py-3 px-6 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-semibold shadow-lg focus:outline-none focus:ring-2 focus:ring-indigo-500">
      <%= chore.persisted? ? "Update Chore" : "Create Chore" %>
    </button>
  </div>
<% end %>
