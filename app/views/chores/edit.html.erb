<div class="max-w-2xl mx-auto py-8">
  <div class="mb-6 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-800">Edit Chore</h1>
      <p class="text-gray-500 mt-1"><%= @chore.name %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "View", @chore, class: "px-4 py-2 text-sm rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium" %>
      <%= link_to "Back to Chores", chores_path, class: "px-4 py-2 text-sm rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium" %>
    </div>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
    <%= render "form", chore: @chore %>
  </div>
</div>
