<%
  category_styles = {
    "event"           => "bg-blue-100 text-blue-700",
    "homework"        => "bg-yellow-100 text-yellow-700",
    "permission_slip" => "bg-red-100 text-red-700",
    "absence_alert"   => "bg-red-100 text-red-700",
    "newsletter"      => "bg-gray-100 text-gray-600",
    "announcement"    => "bg-purple-100 text-purple-700",
    "unknown"         => "bg-gray-100 text-gray-500"
  }
  category_label = (msg.category || "unknown").humanize.downcase
  chip_class = category_styles.fetch(msg.category.to_s, "bg-gray-100 text-gray-500")
  card_class = dimmed ? "opacity-60" : ""
%>

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-5 <%= card_class %>">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <%# Top row: category chip + child name + date %>
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="text-xs font-semibold px-2 py-0.5 rounded-full <%= chip_class %>">
          <%= category_label %>
        </span>
        <% if msg.child_name.present? %>
          <span class="text-xs text-gray-500 font-medium"><%= msg.child_name %></span>
        <% end %>
        <span class="text-xs text-gray-400 ml-auto"><%= msg.created_at.strftime("%-d %b") %></span>
      </div>

      <%# Subject %>
      <h3 class="font-semibold text-gray-900 text-sm leading-snug truncate mb-1">
        <%= msg.subject.presence || "(no subject)" %>
      </h3>

      <%# Parse status — pending spinner or failed warning %>
      <% if msg.parse_status == "pending" %>
        <div class="flex items-center gap-1.5 text-indigo-500 text-xs font-medium mt-1">
          <svg class="animate-spin h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          Rue is reading...
        </div>
      <% elsif msg.parse_status == "failed" %>
        <div class="flex items-center gap-1.5 text-amber-600 text-xs font-medium mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
          </svg>
          Couldn't parse — check original
        </div>
      <% else %>
        <%# AI summary %>
        <% if msg.summary.present? %>
          <p class="text-gray-600 text-sm mt-1 leading-relaxed"><%= msg.summary %></p>
        <% end %>

        <%# Action item %>
        <% if msg.action_item.present? %>
          <div class="mt-2 flex items-start gap-1.5 text-sm text-orange-700 font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            <span><%= msg.action_item %></span>
          </div>
        <% end %>

        <%# Deadline %>
        <% if msg.deadline.present? %>
          <div class="mt-1 flex items-center gap-1.5 text-xs text-gray-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            Due <%= msg.deadline.strftime("%-d %B %Y") %>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Mark Done button (only for non-actioned messages) %>
    <% unless msg.actioned %>
      <%= button_to school_message_path(msg), method: :patch,
            class: "flex-shrink-0 text-xs font-semibold bg-green-50 text-green-700 hover:bg-green-100 px-3 py-1.5 rounded-full transition whitespace-nowrap" do %>
        Mark done
      <% end %>
    <% end %>
  </div>
</div>
