<div class="max-w-3xl mx-auto py-6 pb-24">
  <%# Flash messages %>
  <% if notice %>
    <div class="mb-4 p-4 bg-green-50 border-l-4 border-green-500 text-green-700 rounded-lg"><%= notice %></div>
  <% end %>
  <% if alert %>
    <div class="mb-4 p-4 bg-red-50 border-l-4 border-red-500 text-red-700 rounded-lg"><%= alert %></div>
  <% end %>

  <%# Confetti — only fires when the assignment just became fully approved %>
  <% if notice.present? && @assignments.any? { |a| a.approved == true } %>
    <div data-controller="confetti"></div>
  <% end %>

  <h1 class="text-2xl font-bold mb-1">Hi <%= @child.name %> 👋</h1>
  <div class="text-sm text-gray-500 mb-4"><%= l(Date.current, format: :long) %></div>

  <%# Chore status section — auto-refreshes every 15s so verdicts appear without a page reload %>
  <div data-controller="poll" data-poll-interval-value="15">
    <turbo-frame id="chore_status">

      <%# Token balance + progress bar %>
      <% total          = @assignments.size %>
      <% approved_count = @assignments.count { |a| a.approved == true } %>
      <% pending_count  = @assignments.count { |a| a.latest_attempt&.status_pending? } %>
      <% pct_approved   = total > 0 ? (approved_count * 100.0 / total).round : 0 %>

      <div class="flex items-center justify-between mb-5 bg-white rounded-2xl shadow-sm px-4 py-3">
        <div class="flex items-center gap-2">
          <span class="text-2xl">🪙</span>
          <div>
            <div class="text-xl font-extrabold text-yellow-600 leading-none"><%= @child.token_balance %></div>
            <div class="text-xs text-gray-400">tokens</div>
          </div>
        </div>
        <div class="flex-1 mx-4">
          <div class="flex justify-between text-xs text-gray-500 mb-1">
            <span><%= approved_count %>/<%= total %> done</span>
            <% if pending_count > 0 %>
              <span class="text-yellow-600"><%= pending_count %> being checked</span>
            <% end %>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
            <div class="h-3 bg-green-400 rounded-full transition-all duration-500"
                 style="width: <%= pct_approved %>%"></div>
          </div>
        </div>
        <% if approved_count == total && total > 0 %>
          <span class="text-2xl">🎉</span>
        <% end %>
      </div>

      <%# Today's chores %>
      <h2 class="text-lg font-bold mb-3 text-gray-800">Today's Chores</h2>

      <% if @assignments.empty? %>
        <div class="p-4 bg-gray-50 rounded-xl text-gray-600">No chores for today. Great job! 🎉</div>
      <% else %>
        <div class="space-y-4">
          <% @assignments.each do |assignment| %>
            <% chore = assignment.chore %>
            <% has_tasks = chore&.chore_tasks&.any? %>

            <div class="bg-white rounded-xl shadow-sm overflow-hidden">
              <%# Chore header %>
              <div class="px-4 pt-4 pb-2">
                <div class="font-semibold text-gray-900"><%= chore&.name || 'Chore' %></div>
                <div class="text-sm text-gray-500"><%= chore&.definition_of_done %></div>
              </div>

              <% if has_tasks %>
                <%# ---- PER-STEP FLOW ---- %>
                <div class="px-4 pb-3 space-y-3">
                  <p class="text-xs font-medium text-gray-400 uppercase tracking-wide">Steps to complete:</p>
                  <% chore.chore_tasks.order(:position).each_with_index do |task, i| %>
                    <% task_attempt = assignment.chore_attempts.where(chore_task_id: task.id).order(:created_at).last %>
                    <% task_approved = task_attempt&.status_approved? %>
                    <% task_pending  = task_attempt&.status_pending? %>
                    <% task_rejected = task_attempt&.status_rejected? %>

                    <div class="rounded-lg border <%= task_approved ? 'border-green-200 bg-green-50' : task_pending ? 'border-yellow-200 bg-yellow-50' : task_rejected ? 'border-red-100 bg-red-50' : 'border-gray-200 bg-gray-50' %> p-3">
                      <div class="flex items-start justify-between gap-2">
                        <div class="flex items-start gap-2 min-w-0 flex-1">
                          <span class="text-amber-500 font-bold text-xs mt-0.5 shrink-0"><%= i + 1 %>.</span>
                          <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-gray-800"><%= task.title %></p>
                            <% if task_approved %>
                              <span class="inline-flex items-center gap-1 text-xs text-green-700 font-semibold mt-1">
                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                                </svg>
                                Done!
                              </span>
                            <% elsif task_pending %>
                              <span class="text-xs text-yellow-700 mt-1 block">Your grownup is checking... 👀</span>
                            <% elsif task_rejected %>
                              <span class="text-xs text-red-600 font-medium mt-1 block">Try again! 🔄</span>
                              <% if task_attempt.parent_note.present? %>
                                <p class="text-xs text-red-500 mt-0.5"><%= task_attempt.parent_note %></p>
                              <% end %>
                            <% end %>
                          </div>
                        </div>
                        <%# Model photo thumbnail if present %>
                        <% if task.model_photo.attached? %>
                          <div class="shrink-0">
                            <%= image_tag task.model_photo, class: 'w-14 h-14 object-cover rounded-lg border border-gray-200',
                                  title: "What #{task.title} should look like" %>
                          </div>
                        <% end %>
                      </div>

                      <%# Photo comparison: model photo + child's latest attempt side-by-side %>
                      <% if task_attempt&.photo&.attached? && task.model_photo.attached? %>
                        <div class="mt-2 flex gap-2">
                          <div class="flex-1">
                            <p class="text-xs text-gray-400 mb-1">What it should look like:</p>
                            <%= image_tag task.model_photo, class: 'w-full h-24 object-cover rounded-lg border border-gray-200' %>
                          </div>
                          <div class="flex-1">
                            <p class="text-xs text-gray-400 mb-1">Your photo:</p>
                            <%= image_tag task_attempt.photo, class: 'w-full h-24 object-cover rounded-lg border border-gray-200' %>
                          </div>
                        </div>
                      <% elsif task_attempt&.photo&.attached? %>
                        <div class="mt-2">
                          <p class="text-xs text-gray-400 mb-1">Your photo:</p>
                          <%= image_tag task_attempt.photo, class: 'w-20 h-20 object-cover rounded-lg border border-gray-200' %>
                        </div>
                      <% end %>

                      <%# Action area — photo upload or client-side check depending on task type %>
                      <% if !task_approved && !task_pending %>
                        <% if task.photo_required? %>
                          <%# Photo-required task: show upload form %>
                          <%= form_with url: public_create_attempt_path(params[:token]), method: :post, multipart: true,
                                class: 'mt-3' do |f| %>
                            <%= hidden_field_tag :chore_assignment_id, assignment.id %>
                            <%= hidden_field_tag 'chore_attempt[chore_task_id]', task.id %>
                            <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
                              <%= file_field_tag 'chore_attempt[photo]',
                                    accept: 'image/*', capture: 'environment', required: true,
                                    class: 'flex-1 text-xs text-gray-700 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-amber-50 file:text-amber-700 hover:file:bg-amber-100' %>
                              <button type="submit"
                                      class="shrink-0 px-3 py-1.5 bg-amber-500 text-white rounded-lg text-xs font-semibold hover:bg-amber-600 transition">
                                📷 Submit photo
                              </button>
                            </div>
                          <% end %>
                        <% else %>
                          <%# Non-photo task: one-tap form button — auto-approved server-side %>
                          <%= button_to public_create_attempt_path(params[:token]), method: :post,
                                params: { chore_assignment_id: assignment.id,
                                          'chore_attempt[chore_task_id]' => task.id },
                                class: 'mt-3 w-full px-3 py-2 bg-green-500 text-white rounded-lg text-sm font-semibold hover:bg-green-600 transition' do %>
                            ✓ Mark done
                          <% end %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>

                  <%# All-steps-done status for the overall assignment %>
                  <% if assignment.approved == true %>
                    <div class="flex items-center gap-2 py-2">
                      <span class="px-3 py-1 rounded-full bg-green-100 text-green-800 font-semibold text-sm">All done! ⭐</span>
                    </div>
                  <% end %>
                </div>

              <% else %>
                <%# ---- SIMPLE (WHOLE-CHORE) FLOW ---- %>
                <div class="px-4 pb-4">
                  <%# Chore-level model photo %>
                  <% if chore&.model_photo&.attached? %>
                    <div class="mb-3">
                      <p class="text-xs text-gray-400 mb-1">What it should look like:</p>
                      <%= image_tag chore.model_photo, class: 'w-full max-w-xs h-28 object-cover rounded-lg border border-gray-200' %>
                    </div>
                  <% end %>

                  <%# Task checklist (display only — no photo upload per task) %>
                  <% if chore&.chore_tasks&.any? %>
                    <div class="mb-3">
                      <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">What you need to do:</p>
                      <ol class="space-y-0.5">
                        <% chore.chore_tasks.each_with_index do |task, i| %>
                          <li class="flex items-start gap-1.5 text-sm text-gray-700">
                            <span class="text-amber-500 font-bold text-xs mt-0.5 shrink-0"><%= i + 1 %>.</span>
                            <span><%= task.title %></span>
                          </li>
                        <% end %>
                      </ol>
                    </div>
                  <% end %>

                  <%# Action button / status badge %>
                  <div class="flex justify-end">
                    <% latest = assignment.latest_attempt %>
                    <% if assignment.approved == true %>
                      <span class="px-3 py-1 rounded-full bg-green-100 text-green-800 font-semibold text-sm">Done! ⭐</span>
                    <% elsif latest&.status_pending? %>
                      <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 text-sm font-medium">Your grownup is checking... 👀</span>
                    <% elsif latest&.status_rejected? %>
                      <div class="flex flex-col items-end gap-1">
                        <span class="px-2 py-0.5 rounded-full text-xs bg-red-100 text-red-700 font-semibold">Try again! 🔄</span>
                        <% if latest.parent_note.present? %>
                          <p class="text-xs text-red-500 text-right max-w-[140px]"><%= latest.parent_note %></p>
                        <% end %>
                        <%= link_to 'Try Again', public_new_attempt_path(params[:token], assignment.id),
                              class: 'mt-1 px-3 py-2 bg-indigo-600 text-white rounded-lg text-sm font-semibold hover:bg-indigo-700',
                              data: { turbo_frame: "_top" } %>
                      </div>
                    <% elsif assignment.require_photo? %>
                      <%= link_to 'Mark Done', public_new_attempt_path(params[:token], assignment.id),
                            class: 'px-3 py-2 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700',
                            data: { turbo_frame: "_top" } %>
                    <% else %>
                      <%= button_to public_create_attempt_path(params[:token]), method: :post,
                            params: { chore_assignment_id: assignment.id },
                            class: 'px-3 py-2 bg-indigo-600 text-white rounded-lg font-semibold hover:bg-indigo-700' do %>
                        Mark Done
                      <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <% todays_ready = @assignments.any? && @assignments.all? { |a| a.approved == true } %>
      <% if todays_ready %>
        <div class="mt-6">
          <%= link_to 'Play games 🎮', public_play_path(params[:token]),
                class: 'inline-block px-5 py-3 bg-green-500 text-white font-bold rounded-xl shadow hover:bg-green-600 transition' %>
        </div>
      <% end %>

      <%# Notification opt-in — shown after child submits a chore (has a pending attempt) %>
      <% if @assignments.any? { |a| a.latest_attempt&.status_pending? } && @child.push_subscriptions.none? %>
        <div class="mt-4" data-controller="notifications"
             data-notifications-subscribed-value="false">
          <div data-notifications-target="banner" class="hidden bg-blue-50 border border-blue-200 rounded-xl p-3 flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
              <span class="text-lg">🔔</span>
              <p class="text-sm text-blue-800 font-medium">Want to know the moment your chore is approved?</p>
            </div>
            <button data-action="click->notifications#enable"
                    class="shrink-0 bg-blue-600 text-white text-xs font-semibold px-3 py-1.5 rounded-lg hover:bg-blue-700 transition">
              Notify me!
            </button>
          </div>
          <div data-notifications-target="iosPrompt" class="hidden bg-amber-50 border border-amber-200 rounded-xl p-3 flex items-center gap-2">
            <span>📲</span>
            <p class="text-xs text-amber-800">Add this app to your Home Screen first, then you can get notifications!</p>
          </div>
        </div>
      <% end %>

      <%= render 'bottom_nav', child: @child, token: params[:token], todays_ready: todays_ready %>
    </turbo-frame>
  </div>

  <%# Upcoming chores — collapsed by default %>
  <details class="mt-8 group">
    <summary class="cursor-pointer list-none flex items-center justify-between
                    text-lg font-bold text-gray-700 hover:text-gray-900 select-none
                    py-3 border-t border-gray-200">
      <span>Upcoming chores <span class="text-sm font-normal text-gray-400">(next 90 days)</span></span>
      <svg class="w-5 h-5 text-gray-400 transition-transform duration-200 group-open:rotate-180"
           fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </summary>

    <div class="mt-3">
      <% if @upcoming.blank? %>
        <div class="p-4 bg-gray-50 rounded-xl text-gray-500">No upcoming chores scheduled.</div>
      <% else %>
        <% upcoming_grouped = @upcoming.group_by(&:scheduled_on) %>
        <div class="space-y-6">
          <% upcoming_grouped.each do |date, items| %>
            <div>
              <h3 class="text-sm font-medium text-gray-700 mb-2"><%= l(date, format: :long) %></h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <% items.each do |assignment| %>
                  <div class="p-4 bg-white rounded-xl shadow-sm flex items-start justify-between gap-3">
                    <div class="min-w-0 flex-1">
                      <div class="font-semibold text-gray-900"><%= assignment.chore&.name || 'Chore' %></div>
                      <div class="text-sm text-gray-500"><%= assignment.chore&.definition_of_done %></div>
                      <% if assignment.chore&.chore_tasks&.any? %>
                        <div class="mt-2">
                          <p class="text-xs font-medium text-gray-400 uppercase tracking-wide mb-1">What you need to do:</p>
                          <ol class="space-y-0.5">
                            <% assignment.chore.chore_tasks.each_with_index do |task, i| %>
                              <li class="flex items-start gap-1.5 text-sm text-gray-700">
                                <span class="text-amber-500 font-bold text-xs mt-0.5 shrink-0"><%= i + 1 %>.</span>
                                <span><%= task.title %></span>
                              </li>
                            <% end %>
                          </ol>
                        </div>
                      <% end %>
                    </div>
                    <div class="flex-shrink-0">
                      <% latest = assignment.latest_attempt %>
                      <% if assignment.approved == true %>
                        <span class="px-3 py-1 rounded-full bg-green-100 text-green-800 text-sm font-semibold">Done! ⭐</span>
                      <% elsif latest&.status_pending? %>
                        <span class="px-3 py-1 rounded-full bg-yellow-100 text-yellow-800 text-sm font-medium">Your grownup is checking... 👀</span>
                      <% elsif latest&.status_rejected? %>
                        <div class="flex flex-col items-end gap-1">
                          <span class="px-2 py-0.5 rounded-full text-xs bg-red-100 text-red-700 font-semibold">Try again! 🔄</span>
                          <% if latest.parent_note.present? %>
                            <p class="text-xs text-red-500 text-right max-w-[140px]"><%= latest.parent_note %></p>
                          <% end %>
                        </div>
                      <% else %>
                        <span class="px-3 py-1 rounded-full bg-gray-100 text-gray-600 text-sm">Upcoming</span>
                      <% end %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </details>
</div>
